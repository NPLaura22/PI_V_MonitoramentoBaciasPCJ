# ============================================================
# CONFIGURAÇÕES DO PROJETO — MONITORAMENTO BACIAS PCJ
# ============================================================
# Copie este arquivo para .env e preencha com seus dados reais.
# NUNCA suba o arquivo .env para o GitHub.
# ============================================================

# ID do projeto no Google Cloud (visível no console cloud.google.com)
GOOGLE_CLOUD_PROJECT_ID=monitoramento-pcj-494612

# Nome do dataset no BigQuery (não alterar se já criado)
BIGQUERY_DATASET=pcj_monitoramento

# Nome da tabela principal no BigQuery
BIGQUERY_TABLE_OCORRENCIAS=ocorrencias

# Caminho completo para o arquivo JSON de credenciais do Google Cloud
# Mac/Linux: /Users/seu_usuario/caminho/credentials/pcj-bigquery-key.json
# Windows:   C:\Users\seu_usuario\caminho\credentials\pcj-bigquery-key.json
GOOGLE_APPLICATION_CREDENTIALS=caminho/para/credentials/pcj-bigquery-key.json

# Controla se o pipeline envia dados ao BigQuery após processar
# true  = envia automaticamente ao BigQuery
# false = só salva CSV local em data/raw/ (use para testes)
ENVIAR_PARA_BIGQUERY=false
